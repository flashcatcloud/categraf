{
  "title": "Systemd Services Monitor",
  "uid": "0ee1df6d",
  "tags": [
    "systemd services monitor"
  ],
  "timezone": "browser",
  "schemaVersion": 30,
  "panels": [
    {
      "title": "Systemd Overall Running State (1=OK)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "id": 1,
      "targets": [
        {
          "expr": "systemd_system_running",
          "legendFormat": "{{agent_hostname}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Failed Services (Alert Candidate)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "id": 2,
      "targets": [
        {
          "expr": "systemd_unit_state{state=\"failed\"} > 0",
          "legendFormat": "{{name}} @ {{agent_hostname}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Units by State",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "id": 3,
      "targets": [
        {
          "expr": "systemd_units",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "1m",
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}